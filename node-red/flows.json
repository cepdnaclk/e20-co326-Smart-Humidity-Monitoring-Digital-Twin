    {
        "id": "json_parse_data",
        "type": "function",
        "z": "flow_main",
        "name": "Parse \u00e2\u2020\u2019 InfluxDB Format",
        "func": "// Parse telemetry data and format for InfluxDB 2.0\nvar data = msg.payload;\n\nmsg.payload = {\n    humidity: parseFloat(data.humidity) || 0,\n    temperature: parseFloat(data.temperature) || 0,\n    ml_prediction: parseFloat(data.ml_prediction) || 0,\n    anomaly_score: parseFloat(data.anomaly_score) || 0,\n    dehumidifier_state: data.dehumidifier_state === \"ON\" ? 1 : 0,\n    anomaly_status: data.anomaly_status || \"UNKNOWN\",\n    trend: data.trend || \"UNKNOWN\",\n    device_id: data.device_id || \"humidityTwin01\",\n    is_online: data.status === \"ONLINE\" ? 1 : 0\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 460,
        "y": 120,
        "wires": [
            [
                "influxdb_out"
            ]
        ]
    },

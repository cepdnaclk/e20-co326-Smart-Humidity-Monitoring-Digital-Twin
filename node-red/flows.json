        "id": "comment_rul_pipeline",
        "type": "comment",
        "z": "flow_main",
        "name": "\u00e2\u201d\u20ac\u00e2\u201d\u20ac RUL Estimation Pipeline (Cloud Analytics) \u00e2\u201d\u20ac\u00e2\u201d\u20ac",

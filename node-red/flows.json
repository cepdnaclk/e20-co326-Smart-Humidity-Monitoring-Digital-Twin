        "id": "alert_format_warning",
        "type": "function",
        "z": "flow_main",
        "name": "Format WARNING Alert",
        "func": "var data = msg.payload;\nmsg.payload = {\n    timestamp: data.timestamp,\n    device_id: data.device_id,\n    level: \"WARNING\",\n    anomaly_score: data.anomaly_score,\n    humidity: data.humidity,\n    ml_prediction: data.ml_prediction,\n    message: \"Humidity deviation detected (score: \" + data.anomaly_score + \")\"\n};\nreturn msg;",
        "outputs": 1,
        "x": 440,
        "y": 280,
        "wires": [

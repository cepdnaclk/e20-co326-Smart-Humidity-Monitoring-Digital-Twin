    {
        "id": "rul_function",
        "type": "function",
        "z": "flow_main",
        "name": "RUL Estimation (Linear Trend)",
        "func": "// Remaining Useful Life (RUL) Estimation\n// Uses linear trend analysis on anomaly scores\n\nvar THRESHOLD = 5.0;  // CRITICAL threshold\nvar INTERVAL = 2;     // seconds between readings\nvar WINDOW = 30;      // readings to analyze\n\n// Initialize context storage\nvar scores = context.get('anomaly_scores') || [];\nvar data = msg.payload;\n\n// Skip INITIALIZING readings\nif (data.anomaly_status === 'INITIALIZING') {\n    return [null, null];\n}\n\n// Add current score\nscores.push(parseFloat(data.anomaly_score) || 0);\n\n// Keep only last WINDOW readings\nif (scores.length > WINDOW) {\n    scores = scores.slice(-WINDOW);\n}\ncontext.set('anomaly_scores', scores);\n\n// Need at least 10 readings for RUL\nif (scores.length < 10) {\n    return [null, null];\n}\n\n// Linear regression on scores\nvar n = scores.length;\nvar sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;\nfor (var i = 0; i < n; i++) {\n    sumX += i;\n    sumY += scores[i];\n    sumXY += i * scores[i];\n    sumX2 += i * i;\n}\n\nvar slope = (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX);\nvar intercept = (sumY - slope * sumX) / n;\nvar currentLevel = scores[scores.length - 1];\n\nvar rul_seconds = -1;\nvar rul_status = 'HEALTHY';\nvar rul_display = 'Healthy';\n\nif (slope > 0) {\n    var stepsToThreshold = (THRESHOLD - currentLevel) / slope;\n    if (stepsToThreshold < 0) {\n        rul_seconds = 0;\n        rul_status = 'CRITICAL';\n        rul_display = 'Exceeded';\n    } else {\n        rul_seconds = Math.round(stepsToThreshold * INTERVAL);\n        rul_status = 'DEGRADING';\n        rul_display = rul_seconds + 's';\n    }\n}\n\n// Build InfluxDB message (simple object for v2.0)\nvar influxMsg = {\n    payload: {\n        rul_seconds: rul_seconds,\n        trend_slope: slope,\n        current_score: currentLevel,\n        threshold: THRESHOLD,\n        rul_status: rul_status,\n        device_id: data.device_id || 'humidityTwin01'\n    }\n};\n\n// Build MQTT RUL message\nvar rulMsg = {\n    payload: JSON.stringify({\n        timestamp: data.timestamp,\n        device_id: data.device_id,\n        rul_seconds: rul_seconds,\n        rul_status: rul_status,\n        rul_display: rul_display,\n        trend_slope: Math.round(slope * 10000) / 10000\n    })\n};\n\nreturn [influxMsg, rulMsg];",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 210,
        "y": 460,
        "wires": [
            [
                "influxdb_out_rul"
            ],
            [
                "mqtt_out_rul"
            ]
        ]
